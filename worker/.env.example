# Vigil OCR/extraction worker — environment
# Copy to .env (or set these in your host's dashboard). Never commit real values.

# Supabase project + SERVICE ROLE key (server-only; never ship to a browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Must match the Next app's AI_KEY_ENC_SECRET exactly (used to decrypt each circle's BYOK key)
AI_KEY_ENC_SECRET=

# Shared secret the Next app sends in the x-worker-secret header (must match WORKER_SHARED_SECRET there)
WORKER_SHARED_SECRET=

# Optional managed-key path (off by default). If enabled, extraction uses this app key.
MANAGED_AI_ENABLED=false
MANAGED_ANTHROPIC_API_KEY=

# Port the worker listens on
PORT=8787
