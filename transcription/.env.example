# Vigil transcription service — environment. Never commit real values.

# Shared secret the Next app sends in x-worker-secret (must match TRANSCRIPTION_SHARED_SECRET there)
TRANSCRIPTION_SHARED_SECRET=

# Whisper model: tiny | base | small | medium | large-v3 (bigger = better + slower + more RAM)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Reject audio larger than this many bytes (default 25MB)
MAX_AUDIO_BYTES=26214400

PORT=8000
